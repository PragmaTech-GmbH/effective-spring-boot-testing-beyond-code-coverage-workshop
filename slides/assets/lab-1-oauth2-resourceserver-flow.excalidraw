      "strokeColor": "#f08c00",
      "strokeWidth": 1,
      "roughness": 1,
      "createdAt": "2026-04-10T05:53:21.091Z",
      "updatedAt": "2026-04-10T05:53:21.091Z",
      "version": 1
    },
    {
      "id": "mnshpiv5t9vf8ofwgzg",
      "type": "text",
      "x": 65,
      "y": 318,
      "strokeColor": "#e8590c",
      "text": "In tests: we need a valid JWT whose signature can be verified against known keys → need a running Keycloak (or a stub)",
      "fontSize": 13,
      "createdAt": "2026-04-10T05:53:21.091Z",
      "updatedAt": "2026-04-10T05:53:21.091Z",
      "version": 1
    }
